{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["import", "typescript", "unicorn"],
	"categories": {
		"correctness": "warn",
		"suspicious": "warn",
		"pedantic": "warn"
	},
	"rules": {
		"no-console": "warn"
	},
	"env": {
		"builtin": true
	},
	"globals": {},
	"ignorePatterns": ["dist", "coverage", "node_modules"]
}
