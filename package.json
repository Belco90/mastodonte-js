{
	"name": "mastodonte",
	"version": "0.0.0-semantically-released",
	"description": "🐘 mastodonte - un generador de palabras para los mastodontes, cracks y figuras como tú.",
	"keywords": [
		"dummy",
		"ipsum",
		"lorem",
		"mastodonte",
		"placeholder",
		"text",
		"texto"
	],
	"homepage": "https://github.com/Belco90/mastodonte-js",
	"bugs": {
		"url": "https://github.com/Belco90/mastodonte-js/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Mario Beltrán",
		"email": "me@mario.dev",
		"url": "https://mario.dev/"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Belco90/mastodonte-js.git"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"module": "./dist/index.mjs",
	"typings": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": {
				"default": "./dist/index.d.mts"
			},
			"import": {
				"default": "./dist/index.mjs"
			}
		}
	},
	"scripts": {
		"build": "tsdown",
		"start": "pnpm build --watch",
		"prepare": "husky",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:ci": "pnpm test -- --coverage",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"type-check": "tsc --noEmit",
		"semantic-release": "semantic-release"
	},
	"dependencies": {
		"lorem-ipsum": "^2.0.8"
	},
	"devDependencies": {
		"@types/lodash.deburr": "4.1.9",
		"@vitest/coverage-v8": "4.1.0",
		"husky": "9.1.7",
		"lint-staged": "16.3.3",
		"lodash.deburr": "4.1.0",
		"oxfmt": "0.40.0",
		"oxlint": "1.55.0",
		"oxlint-tsgolint": "0.16.0",
		"semantic-release": "25.0.3",
		"tsdown": "^0.21.2",
		"typescript": "5.9.3",
		"vitest": "4.1.0"
	},
	"engines": {
		"node": "^20.0.0 || ^22.0.0",
		"pnpm": "^9.15.0"
	},
	"packageManager": "pnpm@9.15.9"
}
