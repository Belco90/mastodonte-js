{
	"name": "mastodonte",
	"version": "0.0.0-semantically-released",
	"description": "🐘 mastodonte - un generador de palabras para los mastodontes, cracks y figuras como tú.",
	"keywords": [
		"dummy",
		"ipsum",
		"lorem",
		"mastodonte",
		"placeholder",
		"text",
		"texto"
	],
	"homepage": "https://github.com/Belco90/mastodonte-js",
	"bugs": {
		"url": "https://github.com/Belco90/mastodonte-js/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Mario Beltrán",
		"email": "me@belco.dev",
		"url": "https://belco.dev/"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Belco90/mastodonte-js.git"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"module": "./dist/index.mjs",
	"typings": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": {
				"default": "./dist/index.d.mts"
			},
			"import": {
				"default": "./dist/index.mjs"
			}
		}
	},
	"scripts": {
		"build": "tsdown",
		"start": "pnpm build --watch",
		"prepare": "husky",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:ci": "pnpm test -- --coverage",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"type-check": "tsc --noEmit",
		"semantic-release": "semantic-release"
	},
	"dependencies": {
		"lorem-ipsum": "^2.0.8"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "0.18.2",
		"@types/lodash.deburr": "4.1.9",
		"@vitest/coverage-v8": "4.1.5",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"lodash.deburr": "4.1.0",
		"oxfmt": "0.46.0",
		"oxlint": "1.61.0",
		"oxlint-tsgolint": "0.21.1",
		"publint": "0.3.18",
		"semantic-release": "25.0.3",
		"tsdown": "0.21.9",
		"typescript": "5.9.3",
		"vitest": "4.1.5"
	},
	"engines": {
		"node": "^20.0.0 || ^22.0.0"
	},
	"packageManager": "pnpm@10.33.0"
}
